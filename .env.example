# Mistral AI API key (for behavioral description, policy generation, embeddings, and feedback)
MISTRAL_API_KEY=your_mistral_api_key_here

# AgentQL API key (for semantic DOM querying in Stage 5)
AGENTQL_API_KEY=your_agentql_api_key_here

# Target application — can be any website the agents should explore
TARGET_APP_URL=https://example.com
TARGET_APP_NAME=My App
TARGET_APP_DESCRIPTION=A short description of what this app does

# Production URL blocklist — agent will refuse to run against these
PRODUCTION_URL=https://fun-city-xi.vercel.app
SANDBOX_URL=http://localhost:3000

# PostHog — for downloading session recordings
POSTHOG_PERSONAL_API_KEY=phx_your_personal_api_key_here
POSTHOG_PROJECT_ID=your_project_id_here
POSTHOG_HOST=https://us.posthog.com

# Weights & Biases — for fine-tuning experiment tracking
WANDB_API_KEY=your_wandb_api_key_here

# WhiteCircle — for output quality guardrails
WHITECIRCLE_API_KEY=your_whitecircle_api_key_here
WHITECIRCLE_API_URL=https://us.whitecircle.ai/api/v1
WHITECIRCLE_DEPLOYMENT_ID=your_deployment_id_here

# NVIDIA — for on-device track (build.nvidia.com endpoints)
NVIDIA_API_KEY=your_nvidia_api_key_here
